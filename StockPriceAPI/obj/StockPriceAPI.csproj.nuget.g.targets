    <Import Project="$(NuGetPackageRoot)azure.core\1.55.0\buildTransitive\net10.0\Azure.Core.targets" Condition="Exists('$(NuGetPackageRoot)azure.core\1.55.0\buildTransitive\net10.0\Azure.Core.targets')" />
